{
  "manifest_version": 3,
  "name": "SiteScanner - CMS Vulnerability Detector",
  "version": "1.0.0",
  "description": "Advanced CMS vulnerability detection with detailed analysis for Chrome, Brave, and Firefox",
  "permissions": [
    "activeTab",
    "scripting",
    "webRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SiteScanner - Scan for CMS Vulnerabilities",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["vulnerabilities.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "firefox": {
      "id": "sitescanner@example.com"
    }
  }
}
